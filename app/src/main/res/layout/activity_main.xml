<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_30_30_30">

    <!-- 🔸 Bloco do formulário -->
    <LinearLayout
        android:id="@+id/form_register"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="32dp">

        <TextView
            android:id="@+id/labelProduto"
            android:text="Produto"
            android:textColor="@color/color_245_245_245"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/inputProduto"
            android:hint="Nome"
            android:background="@drawable/bg_rounded_input"
            android:textColorHint="@color/color_179_179_179"
            android:textColor="@color/black_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/labelQuantidade"
            android:text="Quantidade"
            android:textColor="@color/color_245_245_245"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/inputQuantidade"
            android:hint="0"
            android:inputType="number"
            android:background="@drawable/bg_rounded_input"
            android:textColorHint="@color/color_179_179_179"
            android:textColor="@color/black_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/botaoAdicionar"
            android:text="Adicionar ao estoque"
            android:textColor="@color/color_245_245_245"
            android:background="@drawable/bg_rounded_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/botaoSaida"
            android:text="Retirar do estoque"
            android:textColor="@color/color_245_245_245"
            android:background="@drawable/bg_rounded_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- 🔸 Título Estoque -->
    <TextView
        android:id="@+id/text_heading"
        android:text="@string/text_heading"
        android:textColor="@color/color_255_250_250"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/form_register"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:gravity="center"/>

    <!-- 🔸 Lista de produtos -->
    <TextView
        android:id="@+id/listaProdutos"
        android:textColor="@color/color_245_245_245"
        android:textSize="16sp"
        android:background="@drawable/bg_rounded_text_list"
        android:padding="16dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/text_heading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
